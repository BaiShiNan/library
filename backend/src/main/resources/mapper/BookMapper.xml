<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.library.backend.mapper.BookMapper">
    <resultMap id="BaseResultMap" type="com.library.backend.entity.Book">
        <id column="id" property="id" />
        <result column="title" property="title" />
        <result column="author" property="author" />
        <result column="isbn" property="isbn" />
        <result column="category_id" property="categoryId" />
        <result column="description" property="description" />
        <result column="cover_url" property="coverUrl" />
        <result column="file_url" property="fileUrl" />
        <result column="rating" property="rating" />
        <result column="page_count" property="pageCount" />
        <result column="publish_date" property="publishDate" />
        <result column="created_at" property="createdAt" />
    </resultMap>

    <sql id="Base_Column_List">
        id, title, author, isbn, category_id, description, cover_url, file_url, rating, page_count, publish_date, created_at
    </sql>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List" />
        FROM books
        WHERE id = #{id}
    </select>

    <select id="selectList" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List" />
        FROM books
        <where>
            <if test="categoryId != null">
                AND category_id = #{categoryId}
            </if>
            <if test="search != null and search != ''">
                AND (title LIKE CONCAT('%', #{search}, '%') OR author LIKE CONCAT('%', #{search}, '%'))
            </if>
        </where>
        ORDER BY created_at DESC
    </select>

    <select id="selectBatchIds" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List" />
        FROM books
        WHERE id IN
        <foreach item="id" collection="ids" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO books (title, author, isbn, category_id, description, cover_url, file_url, rating, page_count, publish_date, created_at)
        VALUES (#{title}, #{author}, #{isbn}, #{categoryId}, #{description}, #{coverUrl}, #{fileUrl}, #{rating}, #{pageCount}, #{publishDate}, #{createdAt})
    </insert>

    <update id="update">
        UPDATE books
        <set>
            <if test="title != null">title = #{title},</if>
            <if test="author != null">author = #{author},</if>
            <if test="isbn != null">isbn = #{isbn},</if>
            <if test="categoryId != null">category_id = #{categoryId},</if>
            <if test="description != null">description = #{description},</if>
            <if test="coverUrl != null">cover_url = #{coverUrl},</if>
            <if test="fileUrl != null">file_url = #{fileUrl},</if>
            <if test="rating != null">rating = #{rating},</if>
            <if test="pageCount != null">page_count = #{pageCount},</if>
            <if test="publishDate != null">publish_date = #{publishDate},</if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM books WHERE id = #{id}
    </delete>
</mapper>
